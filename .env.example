# 這是一個範例檔案，請複製此檔案並更名為 .env.local 後再進行開發
# *.local 檔案已被 git 忽略，不會被上傳到 GitHub，確保金鑰安全

# 控制開關：true = 使用假資料, false = 連線真實 Supabase
VITE_USE_MOCK_DATA=true

# 以下是你的真實 Supabase 資訊 (若使用假資料模式可不填)
VITE_SUPABASE_URL=你的_SUPABASE_URL
VITE_SUPABASE_ANON_KEY=你的_SUPABASE_ANON_KEY

VITE_FINNHUB_API_KEY=你的finnhub_api_key
