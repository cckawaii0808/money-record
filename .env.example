# 這是一個範例檔案，請複製此檔案並更名為 .env.local 後再進行開發
# *.local 檔案已被 git 忽略，不會被上傳到 GitHub，確保金鑰安全

# =============== Firebase 連線資訊 ===============
# 用於前端連線至 Firebase 服務，可在 Firebase Console「專案設定 > 你的應用程式」取得
# Firebase Web API 金鑰
VITE_FIREBASE_API_KEY=你的_FIREBASE_API_KEY
# Firebase 認證網域，處理登入授權等功能
VITE_FIREBASE_AUTH_DOMAIN=你的_FIREBASE_AUTH_DOMAIN
# Firebase 專案對應的唯一 ID
VITE_FIREBASE_PROJECT_ID=你的_FIREBASE_PROJECT_ID
# Firebase Storage 雲端儲存空間位置
VITE_FIREBASE_STORAGE_BUCKET=你的_FIREBASE_STORAGE_BUCKET
# Firebase 雲端訊息傳遞 (FCM) 用的發送者 ID
VITE_FIREBASE_MESSAGING_SENDER_ID=你的_FIREBASE_MESSAGING_SENDER_ID
# Firebase 前端專屬應用程式 ID
VITE_FIREBASE_APP_ID=你的_FIREBASE_APP_ID

# =============== Finnhub 金鑰 ===============
# 用於獲取股票或金融市場報價資訊的第三方 API 金鑰
VITE_FINNHUB_API_KEY=你的_FINNHUB_API_KEY

# =============== Google Gemini API 金鑰 ===============
# 提供給 AI 助手功能進行對話處理、智慧紀錄與分析的 API 金鑰
# ⚠️ 金鑰若疑似曝光，請隨時回 https://aistudio.google.com/apikey 重新產生並覆蓋
VITE_GEMINI_API_KEY=你的_GEMINI_API_KEY
